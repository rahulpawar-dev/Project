{
  "name": "mediqueue-system",
  "version": "1.0.0",
  "private": true,
  "description": "Complete MERN Stack MediQueue with real-time updates",
  "main": "index.js",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w frontend",
    "start": "npm run start -w backend",
    "install-all": "npm install"
  },
  "keywords": [
    "MERN",
    "Queue Management",
    "Hospital",
    "Patient",
    "Real-time",
    "React",
    "Node.js",
    "MongoDB",
    "Express"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.1"
  }
}
